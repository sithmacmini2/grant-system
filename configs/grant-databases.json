      "fields": {
        "grant_id": "id",
        "name": "title",
        "funder": "funder",
        "deadline": "application_deadline",
        "amount": "grant_amount",
        "criteria": "eligibility_criteria",
        "url": "link"
      },
      "api_key_required": true,
      "rate_limit": 5,
      "enabled": true
    },
    {
      "id": "compasspoint",
      "name": "CompassPoint",
      "type": "foundation",
      "base_url": "https://www.compasspoint.org",
