  "deduplication": {
    "enabled": true,
    "threshold": 0.85,
    "fields": ["name", "funder", "amount"],
    "fuzzy_matching": true
  },
  "global_settings": {
    "timeout_seconds": 30,
    "max_retries": 3,
    "output_format": "json",
    "output_path": "/home/sithmm2_admin/grants-system/data/raw/"
  }
