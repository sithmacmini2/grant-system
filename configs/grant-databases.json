      },
      "rate_limit": 5,
      "enabled": true
    },
    {
      "id": "council-foundations",
      "name": "Council on Foundations",
      "type": "association",
      "base_url": "https://www.cof.org",
      "search_endpoint": "/grant-search",
      "fields": {
        "grant_id": "grantId",
        "name": "grantName",
        "funder": "foundationName",
        "deadline": "deadlineDate",
        "amount": "grantAmount",
        "criteria": " eligibility",
        "url": "grantLink"
      },
      "api_key_required": true,
      "rate_limit": 5,
      "enabled": true
    }
