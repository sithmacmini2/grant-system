{
  "version": "1.0",
  "description": "Opencode scraper configurations for grant databases",
  "target_databases": [
    {
      "id": "grants-gov",
      "name": "Grants.gov",
      "type": "federal",
      "base_url": "https://www.grants.gov/web/grants/search-grants.html",
      "search_params": {
        "query": "filterKeyword",
        "oppStatuses": "open",
        "dateRange": "postingDate"
      },
      "fields": {
        "grant_id": "oppNumber",
        "name": "title",
        "funder": "agency",
        "deadline": "closeDate",
        "amount": "awardCeiling",
        "amount_min": "awardFloor",
        "criteria": "eligibility",
        "url": " OPP_NUMBER"
      },
      "rate_limit": 10,
      "enabled": true
    },
    {
      "id": "foundation-center",
      "name": "Foundation Center",
      "type": "foundation",
      "base_url": "https://foundationcenter.org",
      "search_endpoint": "/grants-search/",
      "fields": {
        "grant_id": "grant_id",
        "name": "grant_name",
        "funder": "funder_name",
        "deadline": "deadline",
        "amount": "amount",
        "criteria": "description",
        "url": "url"
      },
      "api_key_required": true,
      "rate_limit": 5,
      "enabled": true
    },
    {
      "id": "candid",
